{
  "name": "@polyconv/toml",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript TOML to JSON converter utilities for Polyconv with pretty output and sorted keys.",
  "keywords": [
    "polyconv",
    "toml",
    "toml-converter",
    "toml-to-json",
    "toml-parser",
    "json",
    "converter",
    "data-conversion",
    "typescript"
  ],
  "author": "WK Wong <wingkwong.code@gmail.com>",
  "homepage": "https://wingkwong.github.io/polyconv/#package-toml",
  "bugs": {
    "url": "https://github.com/wingkwong/polyconv/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wingkwong/polyconv.git",
    "directory": "packages/toml"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "pnpm run build && node --test test/**/*.test.mjs",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@polyconv/core": "workspace:*"
  },
  "devDependencies": {
    "@polyconv/standard": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
