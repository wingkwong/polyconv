{
  "name": "@polyconv/json",
  "version": "0.2.0",
  "type": "module",
  "description": "JSON converter for polyconv - convert JSON to XML, YAML, TOML, and more",
  "keywords": [
    "polyconv",
    "json",
    "xml",
    "yaml",
    "toml",
    "csv",
    "tsv",
    "ini",
    "env",
    "markdown",
    "html",
    "querystring",
    "converter"
  ],
  "author": "WK Wong <wingkwong.code@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wingkwong/polyconv.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "pnpm run build && node --test test/**/*.test.mjs",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@polyconv/core": "workspace:*",
    "fast-xml-builder": "^1.2.1",
    "js-yaml": "^5.2.1"
  },
  "devDependencies": {
    "@polyconv/standard": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
