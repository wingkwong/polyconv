{
  "name": "@polyconv/core",
  "version": "0.1.2",
  "type": "module",
  "description": "Core TypeScript converter utilities, types, errors, and validation helpers for building Polyconv data format libraries.",
  "keywords": [
    "polyconv",
    "converter",
    "converter-utils",
    "data-conversion",
    "data-format",
    "typescript",
    "types",
    "validation",
    "json-validation",
    "conversion-error"
  ],
  "author": "WK Wong <wingkwong.code@gmail.com>",
  "homepage": "https://wingkwong.github.io/polyconv/#package-core",
  "bugs": {
    "url": "https://github.com/wingkwong/polyconv/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wingkwong/polyconv.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "pnpm run build && node --test",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@polyconv/standard": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
