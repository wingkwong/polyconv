{
  "name": "@polyconv/cli",
  "version": "0.3.0",
  "type": "module",
  "description": "Command-line structured data format converter for Polyconv, with JSON, TOML, YAML, XML, CSV, TSV, INI, ENV, Markdown, HTML, and query string workflows.",
  "keywords": [
    "polyconv",
    "cli",
    "command-line",
    "converter",
    "data-conversion",
    "data-format",
    "json",
    "json-to-yaml",
    "json-to-xml",
    "json-to-toml",
    "json-to-csv",
    "xml",
    "yaml",
    "toml",
    "toml-to-json",
    "csv",
    "tsv",
    "ini",
    "env",
    "markdown",
    "html",
    "querystring",
    "format-json",
    "minify-json"
  ],
  "author": "WK Wong <wingkwong.code@gmail.com>",
  "homepage": "https://github.com/wingkwong/polyconv/tree/develop/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/wingkwong/polyconv/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wingkwong/polyconv.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "polyconv": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "pnpm run build && node --test test/**/*.test.mjs",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@polyconv/core": "workspace:*",
    "@polyconv/json": "workspace:*",
    "@polyconv/toml": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@polyconv/standard": "workspace:*",
    "@types/node": "^24.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
