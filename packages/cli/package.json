{
  "name": "@polyconv/cli",
  "version": "0.1.1",
  "type": "module",
  "description": "CLI for polyconv - convert between data formats",
  "keywords": [
    "polyconv",
    "cli",
    "converter",
    "json",
    "xml",
    "yaml"
  ],
  "author": "WK Wong <wingkwong.code@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wingkwong/polyconv.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "polyconv": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "pnpm run build && node --test test/**/*.test.mjs",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@polyconv/core": "workspace:*",
    "@polyconv/json": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@polyconv/standard": "workspace:*",
    "@types/node": "^24.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
